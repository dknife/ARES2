<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- 장애물 회피 주행 예제 (업그레이드).
       · 시작: 부팅음(도-미-솔) → 레이더(DC 모터) 회전 시작 → 전진
       · 평소: LED를 좌(1·2·3) ↔ 우(4·5·6)로 번갈아 점멸하며 달린다
       · 장애물(20cm 이내): 경고음 + LED 전체 점등, 레이더를 반대로 돌리며
         40cm 이상 열린 곳을 찾을 때까지 좌회전 1초씩 반복
       · 통로 발견: 안전음 + 레이더 정방향 → 그 방향으로 다시 전진
       (바깥 반복은 시뮬레이터 안전장치로 최대 100회까지 도는 무한 반복) -->
  <variables>
    <variable id="dist">거리값</variable>
    <variable id="blink">깜빡</variable>
  </variables>
  <block type="buzzer_on" x="40" y="40">
    <value name="FREQ"><block type="math_number"><field name="NUM">523</field></block></value>
    <value name="DURATION"><block type="math_number"><field name="NUM">0.15</field></block></value>
    <next>
      <block type="buzzer_on">
        <value name="FREQ"><block type="math_number"><field name="NUM">659</field></block></value>
        <value name="DURATION"><block type="math_number"><field name="NUM">0.15</field></block></value>
        <next>
          <block type="buzzer_on">
            <value name="FREQ"><block type="math_number"><field name="NUM">784</field></block></value>
            <value name="DURATION"><block type="math_number"><field name="NUM">0.25</field></block></value>
            <next>
              <block type="variables_set">
                <field name="VAR" id="blink">깜빡</field>
                <value name="VALUE"><block type="math_number"><field name="NUM">0</field></block></value>
                <next>
                  <block type="main_motor_forward">
                    <next>
                      <block type="move_forward">
                        <next>
                          <block type="controls_whileUntil">
                            <field name="MODE">WHILE</field>
                            <value name="BOOL"><block type="logic_boolean"><field name="BOOL">TRUE</field></block></value>
                            <statement name="DO">
                              <block type="check_distance">
                                <field name="VAR" id="dist">거리값</field>
                                <next>
                                  <block type="controls_if">
                                    <mutation else="1"></mutation>
                                    <value name="IF0">
                                      <block type="logic_compare">
                                        <field name="OP">LT</field>
                                        <value name="A"><block type="variables_get"><field name="VAR" id="dist">거리값</field></block></value>
                                        <value name="B"><block type="math_number"><field name="NUM">20</field></block></value>
                                      </block>
                                    </value>
                                    <statement name="DO0">
                                      <block type="main_motor_backward">
                                        <next>
                                          <block type="set_lamp">
                                            <value name="LAMP0"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP1"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP2"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP3"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP4"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP5"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <next>
                                              <block type="buzzer_on">
                                                <value name="FREQ"><block type="math_number"><field name="NUM">196</field></block></value>
                                                <value name="DURATION"><block type="math_number"><field name="NUM">0.2</field></block></value>
                                                <next>
                                                  <block type="buzzer_on">
                                                    <value name="FREQ"><block type="math_number"><field name="NUM">196</field></block></value>
                                                    <value name="DURATION"><block type="math_number"><field name="NUM">0.2</field></block></value>
                                                    <next>
                                                      <block type="controls_whileUntil">
                                                        <field name="MODE">UNTIL</field>
                                                        <value name="BOOL">
                                                          <block type="logic_compare">
                                                            <field name="OP">GTE</field>
                                                            <value name="A"><block type="variables_get"><field name="VAR" id="dist">거리값</field></block></value>
                                                            <value name="B"><block type="math_number"><field name="NUM">40</field></block></value>
                                                          </block>
                                                        </value>
                                                        <statement name="DO">
                                                          <block type="timed_left">
                                                            <value name="SECONDS"><block type="math_number"><field name="NUM">1</field></block></value>
                                                            <next>
                                                              <block type="check_distance">
                                                                <field name="VAR" id="dist">거리값</field>
                                                              </block>
                                                            </next>
                                                          </block>
                                                        </statement>
                                                        <next>
                                                          <block type="buzzer_on">
                                                            <value name="FREQ"><block type="math_number"><field name="NUM">784</field></block></value>
                                                            <value name="DURATION"><block type="math_number"><field name="NUM">0.15</field></block></value>
                                                            <next>
                                                              <block type="buzzer_on">
                                                                <value name="FREQ"><block type="math_number"><field name="NUM">988</field></block></value>
                                                                <value name="DURATION"><block type="math_number"><field name="NUM">0.25</field></block></value>
                                                                <next>
                                                                  <block type="main_motor_forward">
                                                                    <next>
                                                                      <block type="move_forward"></block>
                                                                    </next>
                                                                  </block>
                                                                </next>
                                                              </block>
                                                            </next>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </statement>
                                    <statement name="ELSE">
                                      <block type="controls_if">
                                        <mutation else="1"></mutation>
                                        <value name="IF0">
                                          <block type="logic_compare">
                                            <field name="OP">EQ</field>
                                            <value name="A"><block type="variables_get"><field name="VAR" id="blink">깜빡</field></block></value>
                                            <value name="B"><block type="math_number"><field name="NUM">0</field></block></value>
                                          </block>
                                        </value>
                                        <statement name="DO0">
                                          <block type="set_lamp">
                                            <value name="LAMP0"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP1"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP2"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP3"><block type="math_number"><field name="NUM">0</field></block></value>
                                            <value name="LAMP4"><block type="math_number"><field name="NUM">0</field></block></value>
                                            <value name="LAMP5"><block type="math_number"><field name="NUM">0</field></block></value>
                                          </block>
                                        </statement>
                                        <statement name="ELSE">
                                          <block type="set_lamp">
                                            <value name="LAMP0"><block type="math_number"><field name="NUM">0</field></block></value>
                                            <value name="LAMP1"><block type="math_number"><field name="NUM">0</field></block></value>
                                            <value name="LAMP2"><block type="math_number"><field name="NUM">0</field></block></value>
                                            <value name="LAMP3"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP4"><block type="math_number"><field name="NUM">1</field></block></value>
                                            <value name="LAMP5"><block type="math_number"><field name="NUM">1</field></block></value>
                                          </block>
                                        </statement>
                                        <next>
                                          <block type="variables_set">
                                            <field name="VAR" id="blink">깜빡</field>
                                            <value name="VALUE">
                                              <block type="math_arithmetic">
                                                <field name="OP">MINUS</field>
                                                <value name="A"><block type="math_number"><field name="NUM">1</field></block></value>
                                                <value name="B"><block type="variables_get"><field name="VAR" id="blink">깜빡</field></block></value>
                                              </block>
                                            </value>
                                            <next>
                                              <block type="time_sleep">
                                                <value name="SECONDS"><block type="math_number"><field name="NUM">0.2</field></block></value>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </statement>
                                  </block>
                                </next>
                              </block>
                            </statement>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
